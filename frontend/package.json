    "eslint": "^9.30.0",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "postcss-preset-env": "^10.5.0",
    "prisma": "^6.16.3",
