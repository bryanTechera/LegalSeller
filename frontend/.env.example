# ── Base de datos ─────────────────────────────────────────────────────────────
# Postgres compartida con el backend de agentes (requiere pgvector + pgcrypto).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legalseller

# Límite de conexiones del pool de Prisma (1-100, default 10).
# PRISMA_CONNECTION_LIMIT=10

# ── Backend de agentes ────────────────────────────────────────────────────────
# URL del servicio Mastra. Default: http://localhost:4112
# MASTRA_BASE_URL=http://localhost:4112

# ── Desarrollo ────────────────────────────────────────────────────────────────
# Usuario temporal para probar el chat mientras no hay Auth.js.
# Eliminar cuando se implemente autenticación.
# DEV_USER_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error (default: info)
# LOG_LEVEL=info
