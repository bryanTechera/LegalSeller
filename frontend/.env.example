# ── Base de datos ─────────────────────────────────────────────────────────────
# Postgres compartida con el backend de agentes (requiere pgvector + pgcrypto).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legalseller

# Límite de conexiones del pool de Prisma (1-100, default 10).
# PRISMA_CONNECTION_LIMIT=10

# ── Backend de agentes ────────────────────────────────────────────────────────
# URL del servicio Mastra. Default: http://localhost:4112
# MASTRA_BASE_URL=http://localhost:4112

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ── Versión de la app ─────────────────────────────────────────────────────────
# Expuesta al browser; la reporta GET /api/health. Default: "dev".
# NEXT_PUBLIC_APP_VERSION=

# ── Modo revisión (equipo legal) ──
# Clave compartida para /revision. Sin ella la feature queda apagada (acceso responde 503).
# Se comparte por canal seguro con el equipo legal; rotarla revoca todas las cookies emitidas.
# REVISION_CLAVE=
