# ── Base de datos ─────────────────────────────────────────────────────────────
# Postgres compartida con el frontend. Requiere la extensión pgvector
# (CREATE EXTENSION IF NOT EXISTS vector) y la extensión pgcrypto para
# gen_random_uuid (CREATE EXTENSION IF NOT EXISTS pgcrypto).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legalseller

# ── LLM ───────────────────────────────────────────────────────────────────────
# Vercel AI Gateway: único punto de acceso a los modelos de chat.
AI_GATEWAY_API_KEY=

# Google Generative AI: usado SOLO para embeddings (gemini-embedding-001).
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# Host del server de Mastra. En Railway usar :: (IPv6, red interna).
# HOST=::
# PORT=4112

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error (default: info)
# LOG_LEVEL=info
